#include <stdio.h>

/*
   passo a passo:

	1 - pedir os 5 numeros
	2- abrir o arquivo e escrever nele
	3 - ler o arquivo e depois somar todos os numeros
*/

int main() {
    int num1, num2, num3, num4, num5;
    int soma = 0;


    // Solicitar números
    printf("Digite 5 números inteiros:\n");
    printf("Número 1: ");
    scanf("%d", &num1);
    printf("Número 2: ");
    scanf("%d", &num2);
    printf("Número 3: ");
    scanf("%d", &num3);
    printf("Número 4: ");
    scanf("%d", &num4);
    printf("Número 5: ");
    scanf("%d", &num5);

    // Arquivo escrita
    FILE *f = fopen("numeros.txt", "w");
    if (f == NULL) {
        printf("Erro ao abrir o arquivo para escrita.\n");
        return 1;  // Finaliza se não conseguir abrir o arquivo
    }

    // Gravar os números no arquivo
    fprintf(f, "%d\n", num1);
    fprintf(f, "%d\n", num2);
    fprintf(f, "%d\n", num3);
    fprintf(f, "%d\n", num4);
    fprintf(f, "%d\n", num5);

    fclose(f);

    // Reabrir o arquivo para leitura
    f = fopen("numeros.txt", "r");
    if (f == NULL) {
        printf("Erro ao abrir o arquivo para leitura.\n");
        return 1;
    }

    // Ler os números do arquivo e calcular a soma
    fscanf(f, "%d", &num1);
    fscanf(f, "%d", &num2);
    fscanf(f, "%d", &num3);
    fscanf(f, "%d", &num4);
    fscanf(f, "%d", &num5);

    soma = num1 + num2 + num3 + num4 + num5;
    fclose(f);

    printf("A soma dos números é: %d\n", soma);

	system("pause");
    return 0;
}
