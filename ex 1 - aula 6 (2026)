#include <stdio.h>
#include <stdlib.h>

// pedir 10 numeros e armazenar em um vetor
// dizer qual é o maior valor

int main(int argc, char *argv[]) {

	int num[10];
 	int i;
 	
	for (i = 0; i < 10; i++){
	printf("digite os numeros:\n");
	scanf("%d", &num[i]);
	
}

	int maior = num[0];
	int menor = num[0];
	
	for (i = 1; i < 10; i++) {
        if (num[i] > maior) {
            maior = num[i];
        }
        if (num[i] < menor) {
            menor = num[i];
        }
    }
    
	printf("\nOs valores digitados:\n");
        for (i = 0; i < 10; i++) {
        printf("%d", num[i]);
    }
    
    printf("\nO maior valor digitado foi: %d\n", maior);
    printf("O menor valor digitado foi: %d\n", menor);

	system("pause");	
	return 0;
}
